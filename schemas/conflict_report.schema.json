{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gemmanima.local/schemas/conflict_report.schema.json",
  "title": "GEMMANIMA ConflictReport v0.1",
  "type": "object",
  "required": ["has_conflict", "severity", "fields", "preserve", "modify", "conflicts", "requires_user_confirmation", "proposed_questions"],
  "properties": {
    "has_conflict": { "type": "boolean" },
    "severity": { "type": "string", "enum": ["none", "low", "medium", "high", "critical"] },
    "fields": { "type": "array", "items": { "type": "string" } },
    "preserve": { "type": "array", "items": { "type": "string" } },
    "modify": { "type": "array", "items": { "type": "string" } },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "image_value", "text_value", "severity"],
        "properties": {
          "field": { "type": "string" },
          "image_value": { "type": "string" },
          "text_value": { "type": "string" },
          "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] }
        },
        "additionalProperties": false
      }
    },
    "requires_user_confirmation": { "type": "boolean" },
    "proposed_questions": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
