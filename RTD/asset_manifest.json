{
  "name": "GemmAnima RTD portable asset manifest",
  "version": "v0.1",
  "model_root": {
    "default": "%LOCALAPPDATA%\\GemmAnima\\models",
    "override_env": "GEMMANIMA_MODEL_ROOT"
  },
  "download_registry": "RTD/configs/model_sources.json",
  "groups": {
    "gemma_core": {
      "description": "One shared Gemma GGUF plus task adapters and vision projector.",
      "assets": {
        "shared_base_gguf": {
          "relative_path": "gemma_core/gemma-4-E2B-it-heretic-ara-custom.Q4_K_M.gguf",
          "source": "mradermacher/gemma-4-E2B-it-heretic-ara-custom-GGUF"
        },
        "text_lora": {
          "relative_path": "gemma_core/text-adapter-model-f16.gguf",
          "source": "raspie/gemmanima-adapter-bundle"
        },
        "vision_lora": {
          "relative_path": "gemma_core/vision-tagger-adapter-model-f16.gguf",
          "source": "raspie/gemmanima-adapter-bundle"
        },
        "vision_mmproj": {
          "relative_path": "gemma_core/gemma4-tipo-vision.mmproj-f16.gguf",
          "source": "raspie/gemmanima-adapter-bundle"
        }
      }
    },
    "anima_image_core": {
      "description": "Anima diffusion and VAE files from the original upstream model page.",
      "assets": {
        "diffusion_model": {
          "relative_path": "anima_image_core/anima-base-v1.0.safetensors",
          "source": "circlestone-labs/Anima"
        },
        "vae": {
          "relative_path": "anima_image_core/qwen_image_vae.safetensors",
          "source": "circlestone-labs/Anima"
        }
      }
    },
    "hiddenstage_bridge": {
      "description": "GemmAnima planner, embedding, and bridge profile checkpoints.",
      "assets": {
        "planner_adapter": {
          "relative_path": "hiddenstage_bridge/hiddenstage-planner-adapter.safetensors",
          "source": "raspie/gemmanima-adapter-bundle"
        },
        "planner_vision_embedding": {
          "relative_path": "hiddenstage_bridge/hiddenstage-planner-embed-vision.pt",
          "source": "raspie/gemmanima-adapter-bundle"
        },
        "bridge_checkpoint": {
          "relative_path": "hiddenstage_bridge/kv_proj_hiddenstage_planner_v2.pt",
          "source": "raspie/gemmanima-adapter-bundle"
        },
        "balanced_pose": {
          "relative_path": "hiddenstage_bridge/kv_proj_text_exact_v27_alpha35.pt",
          "source": "raspie/gemmanima-adapter-bundle"
        },
        "style_artist": {
          "relative_path": "hiddenstage_bridge/kv_proj_text_exact_v27_alpha35.pt",
          "source": "raspie/gemmanima-adapter-bundle"
        },
        "text_exact": {
          "relative_path": "hiddenstage_bridge/kv_proj_text_exact_v27_alpha35.pt",
          "source": "raspie/gemmanima-adapter-bundle"
        }
      }
    }
  },
  "notes": [
    "Do not commit downloaded model files to GitHub.",
    "Use GemmAnima.bat download or python -m gemmanima.cli ensure-model-assets --json to populate the local model root.",
    "Developer-only local paths must be supplied through explicit environment variables."
  ]
}
